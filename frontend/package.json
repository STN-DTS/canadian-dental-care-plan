{
  "name": "canadian-dental-care-plan",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postinstall": "patch-package --patch-dir other/patches",
    "build": "npm run build:application && npm run build:server",
    "build:application": "react-router build",
    "build:server": "vite build --config ./vite.server.config.ts",
    "dbg": "cross-env NODE_ENV=development tsx --conditions development --inspect --env-file-if-exists=./.env --import ./app/.server/express-server/opentelemetry.ts ./app/.server/express-server/server.ts",
    "dev": "cross-env NODE_ENV=development tsx --conditions development --env-file-if-exists=./.env --import ./app/.server/express-server/opentelemetry.ts ./app/.server/express-server/server.ts",
    "preview": "npm run build && cross-env NODE_ENV=production SESSION_COOKIE_SECURE=false node --env-file-if-exists=./.env --import ./build/server/opentelemetry.js ./build/server/server.js",
    "start": "cross-env NODE_ENV=production node --import ./build/server/opentelemetry.js ./build/server/server.js",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "run-s --continue-on-error -l format:check typecheck lint:eslint",
    "lint:fix": "run-s --continue-on-error -l format:fix lint:eslint:fix",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./",
    "lint:eslint:fix": "eslint --fix --cache --cache-location ./node_modules/.cache/eslint ./",
    "lint:eslint:summary": "eslint --format summary .",
    "typecheck": "react-router typegen && tsc",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui --coverage.enabled=true"
  },
  "dependencies": {
    "@date-fns/utc": "^2.1.1",
    "@dts-stn/health-checks": "^2.0.0",
    "@dts-stn/invariant": "^1.0.0",
    "@faker-js/faker": "^10.5.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-router/express": "^8.2.0",
    "@react-router/node": "^8.2.0",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "content-disposition": "^2.0.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "eslint-plugin-import-zod": "^1.2.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.10.0",
    "file-type": "^22.0.1",
    "filesize": "^11.0.22",
    "i18next": "^26.3.6",
    "i18next-http-backend": "^4.0.0",
    "inversify": "^8.1.3",
    "isbot": "^5.2.0",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.13.8",
    "markdown-to-jsx": "^9.8.2",
    "micro-memoize": "^5.1.2",
    "mime": "^4.1.0",
    "minimatch": "^10.2.5",
    "moderndash": "^4.0.2",
    "morgan": "^1.11.0",
    "oxide.ts": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-idle-timer": "^5.7.3",
    "react-number-format": "^5.4.5",
    "react-phone-number-input": "^3.4.17",
    "react-router": "^8.2.0",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.6.0",
    "triple-beam": "^1.4.1",
    "undici": "^8.7.0",
    "use-deep-compare": "^1.3.0",
    "usehooks-ts": "^3.1.1",
    "validator": "^13.15.35",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-error-format": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.14.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/compression": "^1.8.1",
    "@types/content-disposition": "^0.5.9",
    "@types/express-session": "^1.19.0",
    "@types/jsdom": "^28.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/source-map-support": "^0.5.10",
    "@types/triple-beam": "^1.3.5",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-formatter-summary": "^2.0.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "globals": "^17.7.0",
    "i18next-cli": "^1.65.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "patch-package": "^8.0.1",
    "playwright-teamcity-reporter": "^1.0.5",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.1",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-mock-extended": "^4.0.0"
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=11.16.0"
  },
  "allowScripts": {
    "@swc/core": false,
    "esbuild": false,
    "protobufjs": false,
    "unrs-resolver": false
  }
}
